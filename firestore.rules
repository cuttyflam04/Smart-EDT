rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: configs
    // Document ID: global
    // Fields:
    //   - whatsappNumber: string (required) - The WhatsApp phone number
    //   - updatedAt: timestamp (optional) - Last update time
    //   - updatedBy: string (optional) - UID of the updater
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "monstertrio04@gmail.com" && request.auth.token.email_verified == true);
    }

    match /configs/global {
      allow read: if true; // Allow anyone to read the config (server needs it)
      allow write: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
