{
  "entities": {
    "User": {
      "title": "User",
      "description": "Student profile information",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "Full name of the student"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Institutional email address"
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "Profile picture URL"
        },
        "classId": {
          "type": "string",
          "description": "ID of the class/group (e.g., L3-INFO)"
        },
        "role": {
          "type": "string",
          "enum": ["student", "admin"],
          "description": "User role"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Account creation timestamp"
        }
      },
      "required": ["displayName", "email", "role"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "A weekly or daily schedule for a specific class",
      "type": "object",
      "properties": {
        "classId": {
          "type": "string",
          "description": "The class this schedule belongs to"
        },
        "weekNumber": {
          "type": "integer",
          "description": "Week number of the year"
        },
        "days": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dayName": { "type": "string" },
              "slots": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "time": { "type": "string" },
                    "subject": { "type": "string" },
                    "room": { "type": "string" },
                    "teacher": { "type": "string" },
                    "type": { "type": "string", "enum": ["CM", "TD", "TP"] }
                  }
                }
              }
            }
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["classId", "days"]
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "whatsappNumber": {
          "type": "string",
          "description": "The WhatsApp phone number for feedback"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        },
        "updatedBy": {
          "type": "string",
          "description": "UID of the user who last updated the config"
        }
      },
      "required": ["whatsappNumber"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual student profiles"
    },
    "schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Class schedules"
    },
    "configs/global": {
      "schema": "AppConfig",
      "description": "Global configuration document"
    }
  }
}
